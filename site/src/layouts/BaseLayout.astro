---
import '../styles/colors_and_type.css';
import '../styles/case-study.css';
import '../styles/motion.css';
import 'katex/dist/katex.min.css';

import Header from '../components/site/Header.astro';
import Footer from '../components/site/Footer.astro';

interface Props {
  title: string;
  description?: string;
  /** Filename in /public used as the social preview; defaults to the site card. */
  image?: string;
  showHeader?: boolean;
  showFooter?: boolean;
}

const DEFAULT_DESCRIPTION =
  'Data engineering, applied machine learning, and quantitative analysis. Case studies that answer a real question, with their limits stated.';

const {
  title,
  description = DEFAULT_DESCRIPTION,
  image = 'og-image.png',
  showHeader = true,
  showFooter = true,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const b = base.endsWith('/') ? base : base + '/';
// Absolute URLs (crawlers require them). Astro.site is set in astro.config.
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(`${b}${image}`, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Favicons (base-path aware; site is served under /Portfolio) -->
    <link rel="icon" href={`${b}favicon.ico`} sizes="any" />
    <link rel="icon" type="image/svg+xml" href={`${b}favicon.svg`} />
    <link rel="apple-touch-icon" href={`${b}apple-touch-icon.png`} />

    <!-- Open Graph / Twitter preview cards -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Mario Casanova" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <!-- Pre-paint: activa el estado oculto del reveal ANTES del primer
         paint, solo si el usuario no pidió motion reducido. Debe ser
         is:inline (sin defer) para evitar flash visible→oculto→reveal. -->
    <script is:inline>
      if (window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
        document.documentElement.classList.add('js-reveal');
      }
    </script>
  </head>
  <body>
    {showHeader && <Header />}
    <slot />
    {showFooter && <Footer />}
  </body>
</html>

<script>
  // Reveal on scroll — una sola vez por elemento, sin JS de fondo.
  // Requisitos: html.js-reveal presente (pre-paint) y targets [data-reveal].
  const root = document.documentElement;
  const els = Array.from(document.querySelectorAll('[data-reveal]'));

  if (root.classList.contains('js-reveal') && els.length > 0) {
    let pending = 0;

    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          entry.target.classList.add('is-revealed');
          io.unobserve(entry.target);
          pending -= 1;
          if (pending === 0) io.disconnect();
        }
      },
      { threshold: 0.15 }
    );

    const vh = window.innerHeight;
    for (const el of els) {
      const r = el.getBoundingClientRect();
      const inInitialViewport = r.top < vh && r.bottom > 0;
      if (inInitialViewport) {
        // Above-the-fold: revelado inmediato, sin transición.
        (el as HTMLElement).style.transition = 'none';
        el.classList.add('is-revealed');
        requestAnimationFrame(() => {
          (el as HTMLElement).style.transition = '';
        });
      } else {
        pending += 1;
        io.observe(el);
      }
    }
    if (pending === 0) io.disconnect();
  }
</script>

<style is:global>
  body {
    margin: 0;
    background-image:
      radial-gradient(rgba(26, 24, 20, 0.020) 1px, transparent 1px),
      radial-gradient(rgba(26, 24, 20, 0.014) 1px, transparent 1px);
    background-size: 3px 3px, 7px 7px;
    background-position: 0 0, 1px 2px;
  }
</style>
