---
const updatedDate = '02.05.2026';
const base = import.meta.env.BASE_URL;
const b = base.endsWith('/') ? base : base + '/';
---

<section class="hero">
  <div class="eyebrow">
    Mexico City&nbsp;&nbsp;·&nbsp;&nbsp;Updated {updatedDate}
  </div>
  <h1 class="hero-title">
    Some problems live<br />
    <em>between</em> disciplines.<br />
    I work there.
  </h1>
  <p class="hero-lede">
    Welcome. I'm Mario — an applied data guy working between data science, data analytics, data engineering, BI, some quantitative finance, MLOps, Applied AI, some computational physics for fun, and a steady habit of reading philosophy and memes. I work around needs. If someone is willing to think the problem through out loud with me, in their own words, even if it sounds like a mess, that's fine for me, from there I do the work. <a href={`${b}about`}>Read more →</a>
  </p>
</section>

<style>
  .hero {
    padding: 120px var(--gutter-desktop) 80px;
    border-bottom: 1px solid var(--rule-soft);
  }
  @media (max-width: 760px) {
    .hero { padding: 64px var(--gutter-mobile) 48px; }
  }

  .eyebrow {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 32px;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: 84px;
    line-height: 0.98;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--ink);
    max-width: 18ch;
    font-weight: 400;
  }
  @media (max-width: 760px) {
    .hero-title { font-size: 48px; line-height: 1.05; }
  }
  .hero-title em {
    font-style: italic;
  }

  .hero-lede {
    font-family: var(--font-serif);
    font-size: 21px;
    line-height: 1.55;
    color: var(--ink-2);
    max-width: 38rem;
    margin-top: 40px;
    margin-bottom: 0;
    text-align: justify;
    hyphens: auto;
  }
  @media (max-width: 760px) {
    .hero-lede { font-size: 17px; margin-top: 24px; }
  }
  .hero-lede a { color: var(--oxblood); }
</style>
