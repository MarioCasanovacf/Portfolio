---
const updatedDate = '10.07.2026';
const base = import.meta.env.BASE_URL;
const b = base.endsWith('/') ? base : base + '/';
---

<section class="hero">
  <div class="eyebrow">
    Mexico City&nbsp;&nbsp;·&nbsp;&nbsp;Updated {updatedDate}
  </div>
  <h1 class="hero-title">
    Some problems live<br />
    <em>between</em> disciplines.<br />
    I work there.
  </h1>
  <p class="hero-lede">
    Every study here started as a question someone actually needed answered, usually arriving half-formed. What follows is the work: the data as it really was, the method with its assumptions tested, the result with its limits stated. Some studies end in a number a team acted on; a few end in an honest "this can't be known from this data" — and I kept those, because knowing where the floor is happens to be the deliverable too. <a href={`${b}about`}>About me →</a>
  </p>
</section>

<style>
  .hero {
    padding: 120px var(--gutter-desktop) 80px;
    border-bottom: 1px solid var(--rule-soft);
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    grid-template-areas:
      'eyebrow eyebrow'
      'title lede';
    gap: 0 64px;
    align-items: end;
  }
  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      grid-template-areas: 'eyebrow' 'title' 'lede';
      align-items: start;
    }
  }
  @media (max-width: 760px) {
    .hero { padding: 64px var(--gutter-mobile) 48px; }
  }

  .eyebrow {
    grid-area: eyebrow;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 32px;
  }

  .hero-title {
    grid-area: title;
    font-family: var(--font-display);
    font-size: 84px;
    line-height: 0.98;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--ink);
    max-width: 18ch;
    font-weight: 400;
  }
  @media (max-width: 760px) {
    .hero-title { font-size: 48px; line-height: 1.05; }
  }
  .hero-title em {
    font-style: italic;
  }

  .hero-lede {
    grid-area: lede;
    font-family: var(--font-serif);
    font-size: 19px;
    line-height: 1.6;
    color: var(--ink-2);
    max-width: 26rem;
    justify-self: end;
    margin: 0;
    text-align: justify;
    hyphens: auto;
  }
  @media (max-width: 900px) {
    .hero-lede { justify-self: start; margin-top: 40px; }
  }
  @media (max-width: 760px) {
    .hero-lede { font-size: 17px; margin-top: 24px; }
  }
  .hero-lede a { color: var(--oxblood); }
</style>
