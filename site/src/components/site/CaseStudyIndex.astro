---
import { studiesByTrack, type Study, type Track } from '../../lib/studies';

interface Props {
  track: Track;
  eyebrow: string;
  title: string;
  lede: string;
}
const { track, eyebrow, title, lede } = Astro.props;

// Number only the real case studies; a companion inherits the prior slot (↳).
function withNumbers(list: Study[]) {
  let c = 0;
  return list.map((s) => {
    if (!s.companion) c += 1;
    return { s, n: s.companion ? '↳' : String(c).padStart(2, '0') };
  });
}
const items = withNumbers(studiesByTrack(track));
const base = import.meta.env.BASE_URL;
---

<section id="code" class="cs-index">
  <div class="cs-eyebrow">{eyebrow}</div>
  <h2 class="cs-title">{title}</h2>
  <p class="cs-lede" set:html={lede}></p>

  <div class="cs-rows">
    {items.map(({ s, n }) => {
      const Tag = s.published ? 'a' : 'div';
      const b = base.endsWith('/') ? base : base + '/';
      const props = s.published ? { href: `${b}case-studies/${s.slug}` } : {};
      return (
        <Tag class:list={['cs-row', { 'cs-row--draft': !s.published, 'cs-row--companion': s.companion }]} {...props}>
          <div class="cs-row__meta">
            <div class="cs-row__n">{s.companion ? '↳' : n}</div>
            {s.published && (
              <div class="cs-row__domain">{s.companion ? 'Interactive' : s.domain}</div>
            )}
          </div>
          <div class="cs-row__body">
            <h3 class="cs-row__title">{s.title}</h3>
            {s.published
              ? <p class="cs-row__dek">{s.dek}</p>
              : <div class="cs-row__draft-tag">Under construction</div>}
          </div>
          <div class="cs-row__methods">
            {s.published && s.methods.map((m, j) => (
              <div class:list={['cs-row__method', { 'is-last': j === s.methods.length - 1 }]}>{m}</div>
            ))}
          </div>
        </Tag>
      );
    })}
    <div class="cs-rows__bottom-rule"></div>
  </div>
</section>

<style>
  .cs-index {
    padding: 64px var(--gutter-desktop) 96px;
  }
  @media (max-width: 760px) {
    .cs-index { padding: 48px var(--gutter-mobile) 64px; }
  }

  .cs-eyebrow {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 12px;
  }
  .cs-title {
    font-family: var(--font-display);
    font-size: 42px;
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 0 0 24px 0;
    color: var(--ink);
    max-width: 20ch;
    font-weight: 400;
  }
  .cs-lede {
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 1.6;
    color: var(--ink-2);
    max-width: 38rem;
    margin: 0 0 56px 0;
    text-align: justify;
    hyphens: auto;
  }

  .cs-rows {
    border-top: 1px solid var(--ink);
  }
  .cs-rows__bottom-rule {
    border-top: 1px solid var(--ink);
  }

  .cs-row {
    display: grid;
    grid-template-columns: 120px 1fr 240px;
    gap: 32px;
    padding: 32px 0;
    align-items: baseline;
    border-bottom: 1px solid var(--ink);
    color: inherit;
    text-decoration: none;
    transition: transform 180ms cubic-bezier(0.2, 0, 0, 1);
  }
  .cs-row:last-of-type { border-bottom: 0; }
  .cs-row:hover {
    transform: translateX(4px);
  }
  @media (max-width: 900px) {
    .cs-row {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }

  .cs-row__n {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-3);
  }
  .cs-row__domain {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-2);
    margin-top: 6px;
  }

  .cs-row__title {
    font-family: var(--font-display);
    font-size: 30px;
    line-height: 1.1;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.01em;
    max-width: 24ch;
    font-weight: 400;
  }
  .cs-row__dek {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 12px 0 0 0;
    max-width: 38rem;
    text-align: justify;
    hyphens: auto;
  }

  .cs-row__methods {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--ink-3);
    line-height: 1.7;
  }
  .cs-row__method {
    border-bottom: 1px solid var(--rule-soft);
    padding: 4px 0;
  }
  .cs-row__method.is-last { border-bottom: 0; }

  /* Under construction — title only; domain, dek and methods withheld. */
  .cs-row--draft {
    cursor: default;
    opacity: 0.5;
  }
  .cs-row--draft:hover { transform: none; }
  .cs-row--draft .cs-row__title { color: var(--ink-2); }

  .cs-row__draft-tag {
    display: inline-block;
    margin-top: 12px;
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-3);
    border: 1px dashed var(--rule-soft);
    padding: 2px 8px;
  }

  /* Companion (interactive tool) — a quieter, sans row tied to the study above. */
  .cs-row--companion {
    padding: 24px 0;
  }
  .cs-row--companion .cs-row__n,
  .cs-row--companion .cs-row__domain {
    color: var(--oxblood);
  }
  .cs-row--companion .cs-row__title {
    font-family: var(--font-sans);
    font-size: 20px;
    line-height: 1.25;
    font-weight: 500;
    letter-spacing: 0;
  }
</style>
