---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VoteExplorer from '~/components/explorer/VoteExplorer.tsx';
import '~/styles/vote-explorer.css';

const base = import.meta.env.BASE_URL;
const b = base.endsWith('/') ? base : base + '/';
---

<BaseLayout title="The LXVI roll-call, vote by vote — Mario Casanova">
  <main class="explorer-page">
    <header class="explorer-head">
      <div class="crumbs">
        <span class="num">02 ⁄ 12</span>
        <span class="domain">Legislative data engineering</span>
        <span class="sep"></span>
        <a class="back" href={`${b}case-studies/legislative-pipeline/`}>← Case study</a>
      </div>
      <h1 class="title">The LXVI roll-call, vote by vote.</h1>
      <p class="lede">
        Every recorded vote of the 2024–2027 Chamber of Deputies, captured one PHP
        page at a time and reconciled to the chamber’s own official tallies. Pick a
        proposal to see how each party — and each of the 554 deputies — voted on it.
      </p>
      <div class="stats">
        <span><b>274</b> recorded votes</span>
        <span><b>554</b> deputies</span>
        <span><b>136,947</b> individual ballots</span>
      </div>
    </header>

    <VoteExplorer client:load />
  </main>
</BaseLayout>

<style>
  .explorer-page {
    max-width: 1120px;
    margin: 0 auto;
    padding: 72px var(--gutter-mobile) 120px;
  }
  @media (max-width: 760px) {
    .explorer-page { padding: 48px var(--gutter-mobile) 80px; }
  }
  .explorer-head { margin-bottom: var(--s-10); }

  .crumbs {
    display: flex;
    align-items: baseline;
    gap: var(--s-4);
    margin-bottom: var(--s-8);
  }
  .crumbs .num {
    font-family: var(--font-mono);
    font-size: var(--t-eyebrow-size);
    color: var(--ink-3);
  }
  .crumbs .domain {
    font-family: var(--font-sans);
    font-size: var(--t-eyebrow-size);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-2);
  }
  .crumbs .sep { flex: 1; border-top: 1px solid var(--rule-soft); transform: translateY(-0.35em); }
  .crumbs .back {
    font-family: var(--font-sans);
    font-size: var(--t-caption-size);
    color: var(--oxblood);
    text-decoration: none;
  }
  .crumbs .back:hover { text-decoration: underline; }

  .title {
    font-family: var(--font-display);
    font-size: 48px;
    line-height: 54px;
    letter-spacing: -0.012em;
    font-weight: 400;
    margin: 0 0 var(--s-5) 0;
    max-width: 20ch;
  }
  .lede {
    font-family: var(--font-serif);
    font-size: var(--t-bodyL-size);
    line-height: var(--t-bodyL-lh);
    color: var(--ink);
    max-width: var(--measure-wide);
    margin: 0 0 var(--s-6) 0;
    text-align: justify;
    hyphens: auto;
    -webkit-hyphens: auto;
  }
  .stats {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-6);
    font-family: var(--font-sans);
    font-size: var(--t-caption-size);
    color: var(--ink-3);
  }
  .stats b { font-family: var(--font-mono); font-size: 15px; color: var(--ink); font-weight: 500; }
</style>
